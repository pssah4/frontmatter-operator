{
  "name": "frontmatter-editor",
  "version": "0.1.0",
  "description": "Filter notes by frontmatter properties and apply bulk edits.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "deploy": "npm run build && ./deploy-local.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "frontmatter",
    "metadata",
    "bulk-edit"
  ],
  "author": "Sebastian Hanke",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "obsidian": "^1.5.7-1",
    "prettier": "^3.2.4",
    "tslib": "^2.6.2",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock": "^3.1075.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1075.0",
    "@smithy/node-http-handler": "^4.8.2"
  }
}
